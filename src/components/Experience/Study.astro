---
import Image from 'astro/components/Image.astro';

interface Props {
    name: string;
    img: string;
    period: string;
    grade: string;
}

const { name, img, period, grade } = Astro.props;
---

<div class="shadow-xl rounded-xl hover:shadow-md transition-all duration-300 hover:cursor-pointer overflow-hidden p-6 flex flex-col gap-4">
    <div class="w-full h-40 flex items-center justify-center overflow-hidden rounded-lg">
        <Image
            src={img}
            alt={name}
            height={120}
            width={500}
            loading='lazy'
            class="w-full h-full object-cover"
        />
    </div>
    <div class="flex flex-col gap-1">
        <h3 class="text-2xl font-semibold leading-tight">
            {name}
        </h3>
        <p class="text-sm font-light tracking-wide">
            {period}
        </p>
        <p class="text-sm leading-relaxed">
            {grade}
        </p>
    </div>
</div>
