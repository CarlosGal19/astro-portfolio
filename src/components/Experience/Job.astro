---
interface Props {
    name: string;
    date: string;
    img: string
    description: string;
}

const { name, date, img, description } = Astro.props;
---

<div class="flex gap-8 p-6 items-center shadow-xl rounded-xl hover:shadow-md transition-all duration-300 hover:cursor-pointer">
    <div class="w-1/3 flex justify-center">
        <img
            src={img}
            alt={name}
            class="rounded-xl object-cover max-h-40"
        >
    </div>
    <div class="flex flex-col justify-center gap-2 w-2/3">
        <h3 class="text-3xl font-semibold leading-tight">
            {name}
        </h3>
        <p class="text-sm font-light tracking-wide">
            {date}
        </p>
        <p class="font-normal leading-relaxed max-w-prose">
            {description}
        </p>
    </div>
</div>
