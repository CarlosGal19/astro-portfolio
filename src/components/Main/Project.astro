---
interface Props {
    name: string;
    description: string;
    img: string
}

const { name, description, img } = Astro.props;
---

<div class="w-full sm:w-1/2 lg:w-1/3 shadow-xl rounded-xl hover:cursor-pointer hover:shadow-md transition-all duration-300">
  <a href="/projects">
    <div class="h-full p-5 flex flex-col gap-4">
      <div class="w-full aspect-video overflow-hidden rounded-lg">
        <img
          src={img}
          alt={name}
          class="w-full h-full object-cover"
        />
      </div>
      <div class="flex flex-col gap-2 grow">
        <p class="text-lg sm:text-xl font-semibold leading-tight">
          {name}
        </p>

        <p class="text-sm sm:text-base font-light leading-relaxed">
          {description}
        </p>
      </div>
    </div>
  </a>
</div>
