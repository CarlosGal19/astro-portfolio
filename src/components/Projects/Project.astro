---
import Image from 'astro/components/Image.astro';

interface Props {
  name: string;
  languages?: string[];
  sm_description: string;
  lg_description?: string;
  img: string;
  github_link?: string;
}

const { name, img, sm_description, languages, lg_description, github_link } = Astro.props;

const modalId = `modal-${name.replace(/\s+/g, '-').toLowerCase()}`;
---

<!-- CARD -->
<div
  class="shadow-xl rounded-xl hover:cursor-pointer hover:shadow-md transition-all duration-300"
  onclick={`document.getElementById('${modalId}').classList.remove('hidden')`}
>
  <div class="h-full p-5 flex flex-col gap-4">
    <div class="w-full aspect-video overflow-hidden rounded-lg">
      <Image
        loading="eager"
        width={120}
        height={120}
        src={img}
        alt={name}
        class="w-full h-full object-cover"
      />
    </div>

    <div class="flex flex-col gap-2 grow">
      <p class="text-lg sm:text-xl font-semibold leading-tight">
        {name}
      </p>

      <p class="text-sm sm:text-base font-light leading-relaxed">
        {sm_description}
      </p>
    </div>
  </div>
</div>

<!-- MODAL -->
<div
  id={modalId}
  class="hidden fixed inset-0 bg-black/60 flex items-center justify-center"
>
  <div class="bg-white p-4 rounded-lg w-[90%] max-w-md relative">
    <button
      class="absolute top-2 right-3 hover:cursor-pointer"
      onclick={`document.getElementById('${modalId}').classList.add('hidden')`}
    >
      ✕
    </button>

    <Image src={img} alt={name} width={400} height={200} class="rounded-md mb-2" />

    <p class="font-bold">{name}</p>
    <p class="text-sm mt-1 font-light">{lg_description ?? sm_description}</p>

    {github_link && (
      <a href={github_link} target="_blank" class="text-blue-500 text-sm inline-block mt-2">
        GitHub
      </a>
    )}
  </div>
</div>
